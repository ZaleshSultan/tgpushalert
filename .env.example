# Telegram secrets are used only by Supabase Edge Functions.
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_CHAT_ID=replace_with_telegram_chat_id
TELEGRAM_WEBHOOK_SECRET=replace_with_random_webhook_secret

# Supabase Edge Functions / REST.
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
CRON_SECRET=replace_with_random_cron_secret

# Moodle calendar export URL. Keep this secret.
MOODLE_ICS_URL=replace_with_moodle_calendar_export_url

# Game deal sync sources.
STEAM_ID64=replace_with_public_steam_id64
STEAM_VANITY=zalewko
STEAM_COUNTRY=KZ
STEAM_LOCALE=russian
STEAM_MIN_DISCOUNT_PERCENT=70
STEAM_MAX_PRICE_KZT=3500
EPIC_COUNTRY=KZ
EPIC_LOCALE=ru

# Supabase alert behavior.
APP_TIMEZONE=Asia/Qyzylorda
ALERT_LOOKAHEAD_HOURS=24
ALERT_COOLDOWN_MINUTES=30
DEFAULT_DATE_ONLY_TASK_REMINDER_HOUR=9
DEFAULT_DATE_ONLY_TASK_REMINDER_MINUTE=0

# Python Google sync worker. Python never talks to Telegram.
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.pickle
GOOGLE_TASKLIST_ID=@default
GOOGLE_SYNC_INTERVAL_SECONDS=300
GOOGLE_CALENDAR_SYNC_DAYS=7
GOOGLE_TASK_SYNC_DAYS=7

# Finance worker.
LOG_LEVEL=INFO
SUPABASE_TIMEOUT_SECONDS=30
DEFAULT_CURRENCY_CODE=KZT
FINANCE_TIMEZONE=Asia/Almaty
FINANCE_WORKER_POLL_SECONDS=60
FINANCE_BOT_META_BATCH_SIZE=25
FINANCE_STALE_CLAIM_MINUTES=5
FINANCE_MAX_PROCESSING_ATTEMPTS=3
LOW_CONFIDENCE_THRESHOLD=0.65
OBSIDIAN_VAULT_PATH=/path/to/your/ObsidianVault

# AI analysis for weekly finance reports. Any OpenAI-compatible chat endpoint works.
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace_with_ai_api_key
AI_MODEL=gpt-5-mini
AI_TIMEOUT_SECONDS=60
AI_HTTP_REFERER=https://your-life-os.example
AI_APP_NAME=LifeOS Finance
